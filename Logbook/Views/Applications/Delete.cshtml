@model Logbook.Models.JobApplication
@{
    ViewData["Title"] = "Delete Application";
}

<div class="page-header">
    <h1>Delete Application</h1>
</div>

<div class="detail-card">
    <p style="margin-bottom: 1rem; color: var(--colour-danger); font-weight: 600;">
        Are you sure you want to delete this application? This action cannot be undone.
    </p>

    <div class="detail-row">
        <span class="detail-label">Company</span>
        <span class="detail-value">@Model.CompanyName</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Role</span>
        <span class="detail-value">@Model.RoleTitle</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Date Applied</span>
        <span class="detail-value">@Model.DateApplied.ToString("dd MMMM yyyy")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value">
            <span class="status-badge status-@Model.Status.ToString().ToLower()">
                @Model.Status
            </span>
        </span>
    </div>

    <div class="form-actions" style="margin-top: 1.5rem;">
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Yes, delete this application</button>
        </form>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
    </div>
</div>
