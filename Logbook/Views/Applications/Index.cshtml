@model IEnumerable<Logbook.Models.JobApplication>
@using Logbook.Models
@{
    ViewData["Title"] = "Applications";
    bool hasFilter = !string.IsNullOrEmpty(ViewBag.CurrentSearch as string) || ViewBag.CurrentStatus != null;
    string currentSort = ViewBag.CurrentSort as string ?? "";
    string currentSearch = ViewBag.CurrentSearch as string ?? "";
    string currentStatus = ViewBag.CurrentStatus?.ToString() ?? "";

    string SortLink(string col)
    {
        var next = currentSort == col ? col + "_desc" : col;
        return $"?sortBy={next}&status={currentStatus}&search={currentSearch}";
    }
    string SortArrow(string col) =>
        currentSort == col ? "▲" : currentSort == col + "_desc" ? "▼" : "";
}

<div class="page-header">
    <h1>My Applications</h1>
    <a asp-action="Create" class="btn btn-primary">+ Add Application</a>
</div>

<form method="get" asp-action="Index" style="display:flex; gap:0.75rem; align-items:flex-end; margin-bottom:1.5rem; flex-wrap:wrap;">
    <div class="form-group" style="margin-bottom:0; min-width:200px;">
        <label for="search">Search</label>
        <input type="text" id="search" name="search"
               value="@currentSearch"
               placeholder="Company or role..."
               class="form-control" />
    </div>
    <div class="form-group" style="margin-bottom:0;">
        <label for="status">Status</label>
        <select id="status" name="status" class="form-control">
            <option value="">All statuses</option>
            @foreach (ApplicationStatus s in Enum.GetValues(typeof(ApplicationStatus)))
            {
                if (ViewBag.CurrentStatus != null && (ApplicationStatus)ViewBag.CurrentStatus == s)
                {
                    <option value="@s" selected>@s</option>
                }
                else
                {
                    <option value="@s">@s</option>
                }
            }
        </select>
    </div>
    <input type="hidden" name="sortBy" value="@currentSort" />
    <button type="submit" class="btn btn-primary">Filter</button>
</form>

@if (hasFilter)
{
    <p style="margin-bottom:1rem;">
        <a asp-action="Index" class="btn btn-secondary">Clear filter</a>
    </p>
}

@if (!Model.Any())
{
    <div class="empty-state">
        @if (hasFilter)
        {
            <p>No applications match your filter.</p>
        }
        else
        {
            <p>No applications logged yet.</p>
            <a asp-action="Create" class="btn btn-primary">Log your first application</a>
        }
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th><a href="@SortLink("company")">Company @SortArrow("company")</a></th>
                <th><a href="@SortLink("role")">Role @SortArrow("role")</a></th>
                <th><a href="@SortLink("date")">Date Applied @SortArrow("date")</a></th>
                <th>Source</th>
                <th><a href="@SortLink("status")">Status @SortArrow("status")</a></th>
                <th>Follow-up</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var app in Model)
            {
                <tr>
                    <td>@app.CompanyName</td>
                    <td>@app.RoleTitle</td>
                    <td>@app.DateApplied.ToString("dd MMM yyyy")</td>
                    <td>@(app.Source ?? "—")</td>
                    <td>
                        <span class="status-badge status-@app.Status.ToString().ToLower()">
                            @app.Status
                        </span>
                    </td>
                    <td>
                        @if (app.FollowUpDate.HasValue)
                        {
                            var isOverdue = app.FollowUpDate.Value.Date < DateTime.Today;
                            var isDueToday = app.FollowUpDate.Value.Date == DateTime.Today;
                            if (isOverdue)
                            {
                                <span class="status-badge status-rejected">Overdue</span>
                            }
                            else if (isDueToday)
                            {
                                <span class="status-badge status-interviewscheduled">Today</span>
                            }
                            else
                            {
                                @app.FollowUpDate.Value.ToString("dd MMM yyyy")
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                    <td class="actions">
                        <a asp-action="Details"
                           asp-route-id="@app.Id"
                           asp-route-status="@currentStatus"
                           asp-route-search="@currentSearch"
                           asp-route-sortBy="@currentSort">View</a>
                        <a asp-action="Edit" asp-route-id="@app.Id">Edit</a>
                        <a asp-action="Delete" asp-route-id="@app.Id"
                           onclick="return confirm('Delete this application?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}