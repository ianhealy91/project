@model Logbook.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h1>Dashboard</h1>
</div>

<form method="get" asp-action="Index" style="display:flex; gap:0.75rem; align-items:flex-end; margin-bottom:1.5rem; flex-wrap:wrap;">
    <div class="form-group" style="margin-bottom:0;">
        <label for="startDate">From</label>
        <input type="date" id="startDate" name="startDate"
               value="@Model.StartDate.ToString("yyyy-MM-dd")"
               class="form-control" />
    </div>
    <div class="form-group" style="margin-bottom:0;">
        <label for="endDate">To</label>
        <input type="date" id="endDate" name="endDate"
               value="@Model.EndDate.ToString("yyyy-MM-dd")"
               class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary" style="margin-top:1.4rem;">Apply</button>
</form>

<div style="margin-top: 2rem;">

    @if (Model.HasNoResults)
    {
        <div class="empty-state">
            <p>No applications found for @Model.DateRangeLabel.</p>
            <a asp-controller="Applications" asp-action="Create" class="btn btn-primary">Log an application</a>
        </div>
    }
    else
    {
        <!-- Summary card  -->
        <div class="detail-card" style="margin-bottom: 1.5rem; max-width: 400px;">
            <div class="detail-row">
                <span class="detail-label">Period</span>
                <span class="detail-value">@Model.DateRangeLabel</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Total applications</span>
                <span class="detail-value" style="font-weight:700; font-size:1.1rem;">@Model.TotalApplications</span>
            </div>
        </div>

        <!-- Status breakdown table  -->
        <table class="table" style="max-width: 500px;">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Count</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.StatusBreakdown)
                {
                    <tr>
                        <td>
                            <span class="status-badge status-@entry.Key.ToString().ToLower()">
                                @entry.Key
                            </span>
                        </td>
                        <td>@entry.Value</td>
                    </tr>
                }
            </tbody>
        </table>
        
        <div style="margin-top: 1.5rem;">
            <a asp-action="Export"
                   asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
                   asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")"
                   class="btn btn-primary">
                Export PDF report
            </a>
        </div>
    }

</div>
