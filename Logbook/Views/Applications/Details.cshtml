@model Logbook.Models.JobApplication
@{
    ViewData["Title"] = $"{Model.RoleTitle} at {Model.CompanyName}";
}

<div class="page-header">
    <h1>@Model.RoleTitle</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        @{
            var returnUrl = ViewBag.ReturnUrl as string;
        }
        <a href="@(returnUrl ?? Url.Action("Index"))" class="btn btn-secondary">Back to Results</a>

    </div>
</div>

<div class="detail-card">
    <div class="detail-row">
        <span class="detail-label">Company</span>
        <span class="detail-value">@Model.CompanyName</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Role</span>
        <span class="detail-value">@Model.RoleTitle</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Date Applied</span>
        <span class="detail-value">@Model.DateApplied.ToString("dd MMMM yyyy")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Source</span>
        <span class="detail-value">@(Model.Source ?? "—")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value">
            <span class="status-badge status-@Model.Status.ToString().ToLower()">
                @Model.Status
            </span>
        </span>
    </div>

    @if (Model.FollowUpDate.HasValue)
    {
        var isOverdue = Model.FollowUpDate.Value.Date < DateTime.Today;
        var isDueToday = Model.FollowUpDate.Value.Date == DateTime.Today;
        <div class="detail-row">
            <span class="detail-label">Follow-up Date</span>
            <span class="detail-value">
                @Model.FollowUpDate.Value.ToString("dd MMMM yyyy")
                @if (isOverdue)
                {
                    <span class="status-badge status-rejected" style="margin-left:0.5rem;">Overdue</span>
                }
                else if (isDueToday)
                {
                    <span class="status-badge status-interviewscheduled" style="margin-left:0.5rem;">Due today</span>
                }
            </span>
        </div>
    }

    <div class="detail-row">
        <span class="detail-label">Added</span>
        <span class="detail-value">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Last Updated</span>
        <span class="detail-value">@Model.UpdatedAt.ToString("dd MMM yyyy, HH:mm")</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="notes-block">
            <h3>Notes</h3>
            <div class="notes-text">@Model.Notes</div>
        </div>
    }
</div>
